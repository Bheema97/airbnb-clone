# Airbnb Clone — Environment Variables

# Backend
DATABASE_URL=sqlite:///./airbnb.db
# Alternative to DATABASE_URL for a mounted persistent disk:
# DATABASE_PATH=/data/airbnb.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SEED_ON_START=false
SEED_IF_EMPTY=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
